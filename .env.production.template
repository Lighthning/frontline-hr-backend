# Frontline HR Backend - Production Environment Variables
# Copy this file to .env in Railway and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string - Railway provides this automatically
# Format: postgresql://user:password@host:port/database
# You don't need to set this manually - Railway will inject it
DATABASE_URL=

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Secret key for signing JWT tokens
# SECURITY: Generate a strong random string (32+ characters)
# Generate using: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# JWT token expiration time (e.g., "24h", "7d", "30d")
JWT_EXPIRES_IN=24h

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Node environment - should be "production" for Railway
NODE_ENV=production

# Port - Railway provides this automatically via $PORT
# Leave this empty or Railway will override it anyway
PORT=

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated list)
# Example: https://frontline-admin.com,https://frontline-mobile.app
# For testing, you can use: http://localhost:3000
ALLOWED_ORIGINS=

# =============================================================================
# SUPER ADMIN ACCOUNT
# =============================================================================
# Initial super admin email - created on first deployment
# This account has full system access
SUPER_ADMIN_EMAIL=admin@frontline.local

# Initial super admin password
# SECURITY: Change this immediately after first login
# Must be at least 8 characters
SUPER_ADMIN_PASSWORD=

# =============================================================================
# OFFICE LOCATION (Geofencing)
# =============================================================================
# Office name (for display purposes)
OFFICE_NAME=Frontline HQ

# Office coordinates (latitude and longitude)
# Example for Riyadh: 24.7136, 46.6753
OFFICE_LAT=

OFFICE_LNG=

# Geofence radius in meters (e.g., 100 for 100m radius)
# Employees must be within this radius to clock in/out
OFFICE_RADIUS=100

# =============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# =============================================================================
# SMTP server for sending emails
# Leave empty if email notifications are not needed
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@frontline.local

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Maximum file upload size in MB
MAX_FILE_SIZE_MB=10

# Allowed file extensions for uploads (comma-separated)
ALLOWED_FILE_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.doc,.docx

# =============================================================================
# RATE LIMITING
# =============================================================================
# Maximum requests per 15 minutes per IP address
RATE_LIMIT_MAX=100

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. Copy this file to Railway's environment variables dashboard
# 2. Generate JWT_SECRET: openssl rand -base64 32
# 3. Set DATABASE_URL (Railway auto-provides this when you add PostgreSQL)
# 4. Configure ALLOWED_ORIGINS with your frontend URLs
# 5. Set office coordinates for geofencing
# 6. Change SUPER_ADMIN_PASSWORD after first login
# 7. Railway automatically sets PORT - don't override it
